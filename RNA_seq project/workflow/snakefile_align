# Example featureCounts workflow rule
# Actual execution performed in Galaxy

configfile: "config/config.yaml"

SAMPLES = list(config["samples"].keys())

rule all:
    input:
        expand(
            "results/bam/{sample}_sorted.bam.bai",
            sample=SAMPLES
        )

rule align_reads:
    input:
        "results/trimmed/{sample}_trimmed.fastq.gz"

    output:
        "results/alignment/{sample}.sam"

    log:
        "logs/hisat2_{sample}.log"

    shell:
        """
        mkdir -p results/alignment

        hisat2 \
        -x index/ecoli_index \
        -U {input} \
        -S {output} \
        > {log} 2>&1
        """

rule sam_to_bam:
    input:
        "results/alignment/{sample}.sam"

    output:
        "results/bam/{sample}.bam"

    shell:
        """
        mkdir -p results/bam

        samtools view -bS {input} > {output}
        """

rule sort_bam:
    input:
        "results/bam/{sample}.bam"

    output:
        "results/bam/{sample}_sorted.bam"

    shell:
        """
        samtools sort {input} -o {output}
        """

rule index_bam:
    input:
        "results/bam/{sample}_sorted.bam"

    output:
        "results/bam/{sample}_sorted.bam.bai"

    shell:
        """
        samtools index {input}
        """
